# Hostinger-compatible SPA routing for Next.js static export
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Prevent rewriting for real files
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rewrite routes to index.html for SPA
  RewriteRule ^.*$ /index.html [L]
</IfModule>

# ─── Correct MIME Types ───────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
  AddType image/svg+xml .svg
  AddCharset UTF-8 .js .mjs .css .html .json .svg .txt
</IfModule>

# ─── Fix ERR_CONTENT_DECODING_FAILED on Hostinger CDN ────────────────────────
# Disable origin compression so CDN doesn't double-encode
<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI "\.(js|mjs|css|json|svg)$" no-gzip
</IfModule>

# Strip any server-side Content-Encoding so CDN receives raw files
# Then tell CDN not to re-encode (no-transform prevents brotli double-encode)
<FilesMatch "\.(js|mjs|css|json|svg)$">
  <IfModule mod_headers.c>
    Header always unset Content-Encoding
    Header always append Cache-Control "no-transform"
  </IfModule>
</FilesMatch>
