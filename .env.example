# SUPABASE CONFIGURATION
# Copy this file to .env.local and populate with your credentials to connect to a live database
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here

# BASE PATH CONFIGURATION
# Leave empty for Hostinger root deployment (darkseagreen-manatee-236634.hostingersite.com)
# Set to '/Kelab-Senshi-Goju-Ryu-Karate-' for GitHub Pages deployment
NEXT_PUBLIC_BASE_PATH=

# SUPABASE SERVER SDK CONFIGURATION
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here
SUPABASE_SECRET_KEY=your-supabase-service-role-key-here
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json
