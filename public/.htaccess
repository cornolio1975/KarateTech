# Hostinger-compatible SPA routing for Next.js static export
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Prevent rewriting for real files
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rewrite routes to index.html for SPA
  RewriteRule ^.*$ /index.html [L]
</IfModule>

# ─── Force Correct MIME Types (Critical for Hostinger) ─────────────────────────
<IfModule mod_mime.c>
  # JavaScript - MUST be application/javascript not text/javascript
  AddType application/javascript .js
  AddEncoding gzip .js.gz
  
  # CSS - MUST be text/css
  AddType text/css .css
  AddEncoding gzip .css.gz
  
  # JSON
  AddType application/json .json
  
  # Set UTF-8 charset
  AddCharset UTF-8 .js .css .html .json .svg .txt
</IfModule>

# ─── Force MIME types even if mod_mime not working ─────────────────────────────
# For NextJS chunks and static assets
<FilesMatch "\.(js)$">
  <IfModule mod_headers.c>
    Header set Content-Type "application/javascript; charset=UTF-8"
  </IfModule>
</FilesMatch>

<FilesMatch "\.(css)$">
  <IfModule mod_headers.c>
    Header set Content-Type "text/css; charset=UTF-8"
  </IfModule>
</FilesMatch>

<FilesMatch "\.(json)$">
  <IfModule mod_headers.c>
    Header set Content-Type "application/json; charset=UTF-8"
  </IfModule>
</FilesMatch>

<FilesMatch "\.(svg)$">
  <IfModule mod_headers.c>
    Header set Content-Type "image/svg+xml; charset=UTF-8"
  </IfModule>
</FilesMatch>
